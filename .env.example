# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/wst-jcc-ecommerce

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# File Upload Limits
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Email (receipt delivery)
# Option A: set SMTP_SERVICE (e.g. Gmail, Outlook) with SMTP_USER/SMTP_PASS
SMTP_SERVICE=Gmail
# Option B: use host/port (leave SMTP_SERVICE empty)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_app_password
# SMTP_FROM_NAME=WST JCC E-Commerce
# SMTP_FROM_EMAIL=your_email@example.com

# Vercel Environment (set automatically by Vercel, or manually for testing)
# VERCEL_URL=your-deployment-url.vercel.app
